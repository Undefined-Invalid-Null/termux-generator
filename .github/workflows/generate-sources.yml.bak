name: Generate Termux Sources

on:
  workflow_dispatch:
    inputs:
      architectures:
        description: "Specify the bootstrap architectures to include in a comma-separated list [aarch64,arm,x86_64,i686]."
        required: false
        default: "aarch64"
      add:
        description: "Include additional packages in bootstrap in a comma-separated list."
        required: false
        default: "xkeyboard-config"
      type:
        description: "Specify the Termux project to fork [f-droid, play-store]. Defaults to f-droid."
        required: false
        default: "f-droid"

jobs:
  generate:
    runs-on: ubuntu-24.04
    steps:
      - name: Clone repository
        uses: actions/checkout@v4

      - name: Set --architectures
        if: "${{ github.event.inputs.architectures != '' }}"
        run: echo "BOOTSTRAP_ARCHITECTURES=--architectures ${{ github.event.inputs.architectures }}" >> $GITHUB_ENV

      - name: Set --add
        if: "${{ github.event.inputs.add != '' }}"
        run: echo "ADDITIONAL_PACKAGES=--additional-packages ${{ github.event.inputs.add }}" >> $GITHUB_ENV

      - name: Set --type
        if: "${{ github.event.inputs.type != '' }}"
        run: echo "APP_TYPE=--app-type ${{ github.event.inputs.type }}" >> $GITHUB_ENV

      - name: Generate Sources
        run: |
          chmod +x scripts/generate-sources.sh
          ./scripts/generate-sources.sh \
            $BOOTSTRAP_ARCHITECTURES \
            $ADDITIONAL_PACKAGES \
            $APP_TYPE

      - name: Upload terminal-emulator module
        uses: actions/upload-artifact@v4.6.0
        with:
          name: terminal-emulator-module
          path: output/terminal-emulator/
          retention-days: 30

      - name: Upload bootstrap
        uses: actions/upload-artifact@v4.6.0
        with:
          name: termux-bootstrap
          path: output/terminal-emulator/assets/bootstrap-*.tar.xz
          retention-days: 30